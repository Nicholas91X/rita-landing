# ─── Supabase ───
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Stripe ───
# Test: sk_test_... / whsec_... — Live: sk_live_... + webhook secret del dashboard LIVE.
# In live i prodotti/prezzi vanno RICREATI (gli ID test non esistono in live).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Opzionale: coupon fedeltà (no-op se non settato).
STRIPE_LOYALTY_COUPON_ID=

# ─── Bunny Stream ───
BUNNY_LIBRARY_ID=
BUNNY_STREAM_API_KEY=
BUNNY_LIBRARY_API_KEY=
NEXT_PUBLIC_BUNNY_CDN_HOSTNAME=

# ─── Site ───
# CRITICO: in produzione deve essere il dominio reale (es. https://www.fitandsmile.it).
# Da questo dipendono magic link, redirect OAuth e il Referer verso Bunny.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_MAINTENANCE_MODE=false

# ─── Email (Resend) ───
RESEND_API_KEY=
# Opzionale: inbox interna che riceve la notifica a ogni nuovo lead (default widestudiodigitale@gmail.com).
LEAD_NOTIFY_EMAIL=

# ─── Upstash Redis (rate limiting) ───
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Secrets ───
# 32-byte hex per HMAC del token di cancellazione GDPR.
GDPR_DELETE_SECRET=
# Protegge gli endpoint cron (trial-reminders, lead-reminders).
CRON_SECRET=

# ─── Web Push (VAPID) ───
VAPID_PUBLIC_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:

# ─── Lead Magnet ───
# CRITICO: UUID del pacchetto "Lezioni Gratis". Se non settato, il flusso lead è no-op silenzioso.
LEAD_MAGNET_PACKAGE_ID=
